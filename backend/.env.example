# Backend Environment Configuration - EXAMPLE
# Copier ce fichier en .env et adapter les valeurs pour votre environnement

# Server Configuration
PORT=3010
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=524288000
UPLOAD_RETENTION_HOURS=48

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=10

# Global Rate Limit
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX_REQUESTS=100
