# Environment Configuration Template
# Copy this file to .env.local and fill in production values

# ============================================================================
# BACKEND Configuration
# ============================================================================

# Node environment (development, staging, production)
NODE_ENV=production

# Backend port
PORT=3010

# CORS origin URLs (comma-separated for multiple origins)
# In production, use only HTTPS URLs
CORS_ORIGIN=https://jt-alwm-frontend.vercel.app,https://www.jt-alwm.example.com

# ============================================================================
# FRONTEND Configuration
# ============================================================================

# API endpoint for frontend
# Should point to your deployed backend service
VITE_API_URL=https://jt-alwm-backend.onrender.com

# ============================================================================
# Docker Configuration
# ============================================================================

# Registry for Docker images
REGISTRY=ghcr.io

# Docker image names
BACKEND_IMAGE=your-org/jt-alwm/backend
FRONTEND_IMAGE=your-org/jt-alwm/frontend

# ============================================================================
# Deployment Services Configuration
# ============================================================================

# Render.com Configuration (Backend)
RENDER_DEPLOY_KEY=your-render-deploy-key
RENDER_BACKEND_SERVICE_ID=your-render-service-id

# Vercel Configuration (Frontend)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# ============================================================================
# Optional: Database/Storage (for future use)
# ============================================================================

# DATABASE_URL=postgresql://user:password@host:5432/database
# S3_BUCKET=your-bucket-name
# S3_REGION=eu-west-1
