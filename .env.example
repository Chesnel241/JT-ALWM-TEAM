# Environment Configuration Template
# Copie ce fichier en `.env` (à la racine) puis renseigne les valeurs.
# `docker-compose.prod.yml` charge ce `.env` dans le conteneur backend.

# ============================================================================
# OBLIGATOIRE — Authentification
# ============================================================================
# Mot de passe global partagé par les pays (login plateforme).
GLOBAL_PASSWORD=change-me-strong-password
# Mot de passe équipe montage (espace montage + rubrique "Mot du JT").
ADMIN_PASSWORD=change-me-admin-password

# ============================================================================
# OBLIGATOIRE — Node / réseau
# ============================================================================
NODE_ENV=production
PORT=3010
# Origine publique du site. Sur VPS avec proxy nginx (frontend) l'API est
# same-origin, mais on garde l'allowlist par sécurité. Mets ton IP ou domaine.
CORS_ORIGIN=http://178.105.250.97
# Nb de proxies devant l'app (nginx = 1). Indispensable pour que req.ip soit
# correct (rate-limit + logs login).
TRUST_PROXY=1

# ============================================================================
# FRONTEND (build) — laisser VIDE sur VPS : l'API est servie en relatif via
# le proxy nginx (cf. docker-compose.prod.yml, arg VITE_API_URL vide).
# ============================================================================
# VITE_API_URL=

# ============================================================================
# STOCKAGE — Cloudflare R2 (recommandé : uploads/exports persistés hors VPS).
# Sans R2, les fichiers restent sur le volume Docker local (uploads_volume).
# ============================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=jt-alwm-uploads

# ============================================================================
# BASE DE DONNÉES — Upstash Redis (persistance du store JSON entre redémarrages).
# Sans Redis, le store est un fichier local (JT_STORE_PATH / volume Docker).
# ============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# RENDU VIDÉO MASTER
# ============================================================================
# 'libass' (défaut, ffmpeg local dans le conteneur) ou 'remotion' (worker
# Cloud Run distant — nécessite RENDER_WORKER_URL + WORKER_KEY + PUBLIC_API_URL).
RENDERER=libass
# Si RENDERER=remotion :
RENDER_WORKER_URL=
WORKER_KEY=
# URL publique de CETTE API (le worker rappelle ici pour la progression).
PUBLIC_API_URL=http://178.105.250.97
# Hôtes additionnels autorisés pour l'URL du master final (CDN custom).
# R2 (*.r2.cloudflarestorage.com / *.r2.dev) est déjà autorisé par défaut.
RESULT_URL_HOSTS=

# ============================================================================
# NOTIFICATIONS PUSH (Web Push / VAPID) — optionnel
# ============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ============================================================================
# OBSERVABILITÉ — optionnel
# ============================================================================
SENTRY_DSN=
ALERT_WEBHOOK_URL=
ALERT_EMAIL=

# ============================================================================
# RÉGLAGES FINS — optionnels (valeurs par défaut raisonnables dans le code)
# ============================================================================
# LOGIN_RATE_LIMIT_MAX=30
# MAX_FILE_SIZE=209715200
# DELIVERY_MAX_FILE_SIZE=419430400
# EDITOR_PRESET=veryfast
# COUNTRIES_JSON=
