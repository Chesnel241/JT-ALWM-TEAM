# Environment Configuration Template
# Copy this file to .env and fill in production values for your VPS.

# ============================================================================
# VPS / Docker Compose (Production mono-serveur Hetzner)
# ============================================================================

# Node environment (development, staging, production)
NODE_ENV=production

# Backend port (interne Docker — exposé via Caddy)
PORT=3010

# CORS origin URLs (comma-separated for multiple origins)
# En production VPS, utiliser l'URL publique HTTPS de Caddy
CORS_ORIGIN=https://jt-alwm-team.duckdns.org

# API endpoint pour le frontend (build Docker)
# Vide = même origine (Caddy gère le proxy /api → backend)
VITE_API_URL=

# Mots de passe (OBLIGATOIRES en prod — le backend refuse de démarrer sans).
# Générer des mots de passe forts : openssl rand -base64 24
GLOBAL_PASSWORD=change-me-immediately
ADMIN_PASSWORD=change-me-admin-immediately

# Secret partagé backend <-> worker de rendu. Générer : openssl rand -hex 32
# Obligatoire (docker-compose.yml échoue si vide).
WORKER_KEY=

# ============================================================================
# Optionnel : Persistance Redis (recommandé pour haute disponibilité)
# ============================================================================
# Si configuré, les métadonnées survivent à la recréation du volume Docker.
# Sinon, les données vivent dans le volume Docker local (persistant sur VPS).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_TOKEN=

# ============================================================================
# Optionnel : Sentry (Error Tracking)
# ============================================================================
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# ============================================================================
# Optionnel : R2 / S3 (stockage externe des exports vidéo)
# ============================================================================
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# ============================================================================
# Optionnel : Notifications Web Push
# ============================================================================
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ============================================================================
# Optionnel : Alertes Webhook (Discord/Slack)
# ============================================================================
# ALERT_WEBHOOK_URL=
# ALERT_EMAIL=
